# ============ SUPABASE CONFIGURATION (Required) ============
# Get these from: https://app.supabase.com/project/[ID]/settings/api
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ============ GEMINI API KEY (Required) ============
# For AI features. Get from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ============ APP URL ============
# Local development
VITE_APP_URL="http://localhost:3000"
# Or for production (Vercel):
# VITE_APP_URL="https://your-domain.vercel.app"

# ============ DEMO CREDENTIALS (Development only) ============
# WARNING: Only use for local development. Remove/change before production.
