# n8n Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change-me-in-production-with-a-random-key

# Database - n8n (Internal)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=n8n_password

# Database - POS 360 (Application)
POS_DB_HOST=postgres-pos
POS_DB_PORT=5432
POS_DB_NAME=pos_360
POS_DB_USER=pos_user
POS_DB_PASSWORD=pos_password

# Slack Integration (Optional)
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_SUCCESS_CHANNEL=C1234567890
SLACK_ERROR_CHANNEL=C0987654321

# Email Notifications (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@pos360.com

# Node Environment
NODE_ENV=production

# Webhook Configuration
WEBHOOK_TUNNEL_URL=http://localhost:5678/

# Timezone
TZ=America/Bogota
